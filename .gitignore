# --- Build artifacts (MSVC + autotools/gcc) ---
*.o
*.obj
*.res
*.exe
*.dll
*.pdb
*.ilk
*.exp
*.lib
*.a
*.lo
.deps/
.libs/
build.log

# --- autotools generated output (the *.in / configure templates stay) ---
files/Makefile
config.cache
config.log
config.status

# --- Game data & runtime-generated files ---
# IWADs are copyrighted id Software data -- bring your own, never commit them.
*.wad
*.WAD
# Exception: run/buddy.wad is OUR voice asset (pre-rendered OGG phrases in a
# Doom PWAD), not a game IWAD.  It must be in the repo so the engine can
# play the buddy voice offline without anyone re-running the ElevenLabs
# baker.  Listed AFTER the general *.wad rule so it takes precedence.
!run/buddy.wad
doom.cfg
.doomrc
doomsav*.dsg
*.log

# --- Local scratch (screenshots, icon previews) ---
*Datei-Explorer*.png
icon_preview.png
exe_icon_check.png

# Throwaway scratch directory (test artifacts, downloaded zips, etc.)
tmp/

# --- Python (ollama_director.py / gpumon.py) ---
__pycache__/
*.pyc

# --- Editor / OS noise ---
*~
*.swp
.DS_Store
Thumbs.db
.vs/
*.err

# bare (extensionless) build outputs
files/aidoom
files/doom
# build.sh copies the binary here too
run/aidoom
run/doom
# SDL3 config tool binary (built by tools/build_config.sh, copied to run/)
tools/aidoom_config
run/aidoom_config
# runtime config (written by the game / config app; user-specific)
aidoom.cfg
run/aidoom.cfg
aidoom2.cfg
run/aidoom2.cfg

# local debug screenshots (not part of the repo; hero.png is the only tracked image)
Bildschirmfoto_*.png
stuck.png
hand.png

# runtime artifacts
buddy_say.txt
run/buddy_say.txt
tools/aidoom_config.exe
run/aidoom_config.exe
tools/gpumon_sdl
run/gpumon_sdl
tools/gpumon_sdl.exe
run/gpumon_sdl.exe

# CMake build output
/build/
/build_cmake/
build_cmake_build.log
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
tools/gpumon
run/gpumon
