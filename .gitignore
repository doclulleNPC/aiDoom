*.wad
*.WAD
doom.cfg
.doomrc
doomsav*.dsg
*.log

# --- Local scratch (screenshots, icon previews) ---
*Datei-Explorer*.png
icon_preview.png
exe_icon_check.png

# --- Python (ollama_director.py / gpumon.py) ---
__pycache__/
*.pyc

# --- Editor / OS noise ---
*~
*.swp
.DS_Store
Thumbs.db
.vs/
*.err

# bare (extensionless) build outputs
files/aidoom
files/doom
# build.sh copies the binary here too
run/aidoom
run/doom
# SDL3 config tool binary (built by tools/build_config.sh)
tools/aidoom_config
