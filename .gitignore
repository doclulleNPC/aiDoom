*.o
*.obj
*.res
*.exe
*.dll
*.pdb
*.ilk
*.exp
*.lib
*.a
*.lo
.deps/
.libs/
build.log

# --- autotools generated output (the *.in / configure templates stay) ---
files/Makefile
config.cache
config.log
config.status

# --- Game data & runtime-generated files ---
